# ─── 의존성 ───
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── 빌드 산출물 ───
/.next/
/out/
/build
/dist

# ─── 테스트/커버리지 ───
/coverage
*.lcov

# ─── 환경 변수 (시크릿 포함 — 절대 커밋 금지) ───
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── 로그 ───
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── 타입스크립트 ───
*.tsbuildinfo
next-env.d.ts

# ─── 런타임/캐시 ───
.cache/
.vercel
.turbo

# ─── OS / 에디터 ───
.DS_Store
*.pem
Thumbs.db
.idea/
*.swp
*.swo

# ─── VS Code (워크스페이스 설정은 선택적으로 유지) ───
.vscode/*
!.vscode/extensions.json
